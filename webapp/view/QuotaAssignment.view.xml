<mvc:View
    controllerName="com.ccb.quota.controller.QuotaAssignment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">
    
    <Page
        id="quotaAssignmentPage"
        title="{i18n>quotaAssignmentTitle}"
        showNavButton="false">
        
        <headerContent>
            <Button
                id="myAssignmentsButton"
                icon="sap-icon://calendar"
                text="{i18n>myAssignments}"
                press=".onNavigateToMyAssignments" />
            <Button
                id="refreshButton"
                icon="sap-icon://refresh"
                press=".onRefresh" />
        </headerContent>

        <content>
            <VBox class="sapUiSmallMargin quotaContentContainer">
                
                <!-- Week Selection -->
                <l:HorizontalLayout class="sapUiSmallMarginBottom quotaWeekSelector">
                    <Button
                        icon="sap-icon://navigation-left-arrow"
                        press=".onPreviousWeek"
                        tooltip="{i18n>previousWeek}"
                        type="Transparent" />
                    <Title
                        text="{/currentWeekLabel}"
                        class="sapUiSmallMarginBegin sapUiSmallMarginEnd"
                        level="H4" />
                    <Button
                        icon="sap-icon://navigation-right-arrow"
                        press=".onNextWeek"
                        tooltip="{i18n>nextWeek}"
                        type="Transparent" />
                </l:HorizontalLayout>

                <!-- Info Message for No Children -->
                <MessageStrip
                    visible="{= !${/hasChildren}}"
                    text="{/noChildrenMessage}"
                    type="Information"
                    showIcon="true"
                    class="sapUiMediumMarginBottom">
                </MessageStrip>

                <!-- Info Text -->
                <Text
                    visible="{= ${/hasChildren}}"
                    text="Seleccione los días de la semana para los cuales requiere el cupo."
                    class="quotaInfoText sapUiSmallMarginBottom" />

                <!-- Quota Table -->
                <Table
                    id="quotaTable"
                    visible="{= ${/hasChildren}}"
                    items="{/children}"
                    mode="None"
                    class="quotaTable sapUiSmallMarginTop">
                    <columns>
                        <Column width="15rem" hAlign="Begin">
                            <header>
                                <Label text="NOMBRES Y APELLIDOS" class="quotaTableHeader" />
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="LUNES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/0/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="MARTES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/1/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="MIÉRCOLES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/2/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="JUEVES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/3/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="VIERNES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/4/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <!-- Name Cell -->
                                <Text text="{fullName}" class="quotaNameText" />
                                
                                <!-- Monday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/0/selected}"
                                        enabled="{
                                            parts: ['days/0/available', 'days/0/alreadyAssigned'],
                                            formatter: '.formatter.isDaySelectableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="0" />
                                        </customData>
                                    </CheckBox>
                                </VBox>
                                
                                <!-- Tuesday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/1/selected}"
                                        enabled="{
                                            parts: ['days/1/available', 'days/1/alreadyAssigned'],
                                            formatter: '.formatter.isDaySelectableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="1" />
                                        </customData>
                                    </CheckBox>
                                </VBox>
                                
                                <!-- Wednesday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/2/selected}"
                                        enabled="{
                                            parts: ['days/2/available', 'days/2/alreadyAssigned'],
                                            formatter: '.formatter.isDaySelectableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="2" />
                                        </customData>
                                    </CheckBox>
                                </VBox>
                                
                                <!-- Thursday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/3/selected}"
                                        enabled="{
                                            parts: ['days/3/available', 'days/3/alreadyAssigned'],
                                            formatter: '.formatter.isDaySelectableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="3" />
                                        </customData>
                                    </CheckBox>
                                </VBox>
                                
                                <!-- Friday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/4/selected}"
                                        enabled="{
                                            parts: ['days/4/available', 'days/4/alreadyAssigned'],
                                            formatter: '.formatter.isDaySelectableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="4" />
                                        </customData>
                                    </CheckBox>
                                </VBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

                <!-- Checkboxes for Terms -->
                <VBox visible="{= ${/hasChildren}}" class="quotaTermsContainer sapUiMediumMarginTop">
                    <CheckBox
                        id="termsCheckbox"
                        text="Acepto las condiciones y lineamientos del servicio"
                        class="quotaTermsCheckbox" />
                    <CheckBox
                        id="privacyCheckbox"
                        text="Acepto la política de tratamiento de datos personales"
                        class="quotaPrivacyCheckbox" />
                </VBox>

                <!-- Action Buttons -->
                <HBox
                    visible="{= ${/hasChildren}}"
                    justifyContent="End"
                    class="quotaActionButtons sapUiMediumMarginTop">
                    <Button
                        id="cancelButton"
                        text="Cancelar"
                        press=".onCancel"
                        type="Default"
                        class="sapUiSmallMarginEnd" />
                    <Button
                        id="saveButton"
                        text="Aceptar"
                        press=".onSaveAssignments"
                        type="Emphasized"
                        enabled="{= ${/selectedCount} > 0}" />
                </HBox>

            </VBox>
        </content>

    </Page>
</mvc:View>
