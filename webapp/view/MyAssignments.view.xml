<mvc:View
    controllerName="com.ccb.quota.controller.MyAssignments"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Page
        id="myAssignmentsPage"
        title="{i18n>myAssignmentsTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <headerContent>
            <Button
                id="refreshAssignmentsButton"
                icon="sap-icon://refresh"
                press=".onRefresh" />
            <ToolbarSpacer />
            <Text
                text="{app>/userName}"
                class="sapUiTinyMarginEnd" />
            <core:Icon
                src="sap-icon://person-placeholder"
                color="#0854A0" />
        </headerContent>

        <content>
            <VBox class="sapUiSmallMargin quotaContentContainer">

                <!-- Week Title -->
                <l:HorizontalLayout class="sapUiSmallMarginBottom quotaWeekSelector">
                    <Title
                        text="{/currentWeekLabel}"
                        class="quotaWeekTitle"
                        level="H4" />
                </l:HorizontalLayout>

                <!-- Info Message when no assignments -->
                <MessageStrip
                    visible="{= ${/childrenAssignments}.length === 0}"
                    text="No hay asignaciones para esta semana"
                    type="Information"
                    showIcon="true"
                    class="sapUiMediumMarginBottom">
                </MessageStrip>

                <!-- Assignments Table (grouped by child) -->
                <Table
                    id="assignmentsTable"
                    items="{/childrenAssignments}"
                    mode="None"
                    visible="{= ${/childrenAssignments}.length > 0}"
                    class="quotaAssignmentsTable">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Lista de Asignaciones" level="H4" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="auto" hAlign="Begin">
                            <Text text="Nombre Dependiente" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true" hAlign="Begin">
                            <Text text="Días Reservados" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                            <Text text="Estado" />
                        </Column>
                        <Column hAlign="Center">
                            <Text text="Acción" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{fullName}" />
                                <Text text="{daysText}" />
                                <ObjectStatus
                                    text="{
                                        path: 'overallStatus',
                                        formatter: '.formatter.formatAssignmentStatus'
                                    }"
                                    state="{
                                        path: 'overallStatus',
                                        formatter: '.formatter.getAssignmentStatusState'
                                    }" />
                                <Button
                                    text="Editar reserva"
                                    type="Default"
                                    press=".onEditAssignment" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

            </VBox>
        </content>

    </Page>
</mvc:View>
