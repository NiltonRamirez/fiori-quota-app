<mvc:View
    controllerName="com.ccb.quota.controller.MyAssignments"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">
    
    <Page
        id="myAssignmentsPage"
        title="{i18n>myAssignmentsTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack">
        
        <headerContent>
            <Button
                id="refreshAssignmentsButton"
                icon="sap-icon://refresh"
                press=".onRefresh" />
        </headerContent>

        <content>
            <VBox class="sapUiSmallMargin quotaContentContainer">
                
                <!-- Week Title (Fixed) -->
                <l:HorizontalLayout class="sapUiSmallMarginBottom quotaWeekSelector">
                    <Title
                        text="{/currentWeekLabel}"
                        class="quotaWeekTitle"
                        level="H4" />
                </l:HorizontalLayout>

                <!-- Info Message when no assignments -->
                <MessageStrip
                    visible="{= ${/assignments}.length === 0}"
                    text="No hay asignaciones para esta semana"
                    type="Information"
                    showIcon="true"
                    class="sapUiMediumMarginBottom">
                </MessageStrip>

                <!-- Assignments Table -->
                <Table
                    id="assignmentsTable"
                    items="{/assignments}"
                    mode="MultiSelect"
                    growing="true"
                    growingThreshold="20"
                    sticky="ColumnHeaders"
                    visible="{= ${/assignments}.length > 0}"
                    class="quotaAssignmentsTable">
                    
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Lista de Asignaciones" level="H4" />
                            <ToolbarSpacer />
                            <Button
                                id="cancelButton"
                                text="Cancelar Seleccionados"
                                type="Reject"
                                press=".onCancelSelected" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="auto">
                            <Text text="Fecha" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Día" />
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true" hAlign="Begin">
                            <Text text="Nombre Dependiente" />
                        </Column>
                        <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                            <Text text="Estado" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem type="Active">
                            <cells>
                                <ObjectIdentifier
                                    title="{
                                        path: 'date',
                                        formatter: '.formatter.formatDate'
                                    }"
                                    text="{dependentId}" />
                                <Text
                                    text="{
                                        path: 'dayOfWeek',
                                        formatter: '.formatter.formatDayOfWeek'
                                    }" />
                                <Text text="{fullName}" />
                                <ObjectStatus
                                    text="{
                                        path: 'assignmentStatus',
                                        formatter: '.formatter.formatAssignmentStatus'
                                    }"
                                    state="{
                                        path: 'assignmentStatus',
                                        formatter: '.formatter.getAssignmentStatusState'
                                    }" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

            </VBox>
        </content>

        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Text text="Total de asignaciones: {= ${/assignments}.length }" />
            </Toolbar>
        </footer>

    </Page>
</mvc:View>
