<mvc:View
    controllerName="com.ccb.quota.controller.EditAssignment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Page
        id="editAssignmentPage"
        title="{i18n>editAssignmentTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <headerContent>
            <Button
                id="refreshButton"
                icon="sap-icon://refresh"
                press=".onRefresh" />
            <ToolbarSpacer />
            <Text
                text="{app>/userName}"
                class="sapUiTinyMarginEnd" />
            <core:Icon
                src="sap-icon://person-placeholder"
                color="#0854A0" />
        </headerContent>

        <content>
            <VBox class="sapUiSmallMargin quotaContentContainer">

                <!-- Week Title -->
                <l:HorizontalLayout class="sapUiSmallMarginBottom quotaWeekSelector">
                    <Title
                        text="{/currentWeekLabel}"
                        class="quotaWeekTitle"
                        level="H4" />
                </l:HorizontalLayout>

                <!-- Info Text -->
                <Text
                    text="Modifique los días de la semana para los cuales requiere el cupo. Los días marcados ya tienen reserva activa."
                    class="quotaInfoText sapUiSmallMarginBottom" />

                <!-- Edit Table -->
                <Table
                    id="editTable"
                    items="{/children}"
                    mode="None"
                    class="quotaTable sapUiSmallMarginTop">
                    <columns>
                        <Column width="15rem" hAlign="Begin">
                            <header>
                                <Label text="NOMBRES Y APELLIDOS" class="quotaTableHeader" />
                            </header>
                        </Column>
                        <Column width="5rem" hAlign="Center">
                            <header>
                                <Label text="TODOS" class="quotaTableHeader quotaSelectAllHeader" />
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="LUNES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/0/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="MARTES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/1/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="MIÉRCOLES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/2/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="JUEVES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/3/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                        <Column width="auto" hAlign="Center" minScreenWidth="Tablet" demandPopin="false">
                            <header>
                                <VBox alignItems="Center" class="quotaDayColumn">
                                    <Label text="VIERNES" class="quotaDayLabel" />
                                    <Text text="{/weekDays/4/quotaText}" class="quotaCuposText" />
                                </VBox>
                            </header>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <!-- Name Cell -->
                                <Text text="{fullName}" class="quotaNameText" />

                                <!-- Select All for this child -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        select=".onSelectAllForChild"
                                        class="quotaDayCheckbox quotaSelectAllCheckbox" />
                                </VBox>

                                <!-- Monday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/0/selected}"
                                        enabled="{
                                            parts: ['days/0/available', 'days/0/alreadyAssigned'],
                                            formatter: '.formatter.isDayEditableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="0" />
                                        </customData>
                                    </CheckBox>
                                </VBox>

                                <!-- Tuesday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/1/selected}"
                                        enabled="{
                                            parts: ['days/1/available', 'days/1/alreadyAssigned'],
                                            formatter: '.formatter.isDayEditableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="1" />
                                        </customData>
                                    </CheckBox>
                                </VBox>

                                <!-- Wednesday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/2/selected}"
                                        enabled="{
                                            parts: ['days/2/available', 'days/2/alreadyAssigned'],
                                            formatter: '.formatter.isDayEditableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="2" />
                                        </customData>
                                    </CheckBox>
                                </VBox>

                                <!-- Thursday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/3/selected}"
                                        enabled="{
                                            parts: ['days/3/available', 'days/3/alreadyAssigned'],
                                            formatter: '.formatter.isDayEditableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="3" />
                                        </customData>
                                    </CheckBox>
                                </VBox>

                                <!-- Friday -->
                                <VBox alignItems="Center" justifyContent="Center">
                                    <CheckBox
                                        selected="{days/4/selected}"
                                        enabled="{
                                            parts: ['days/4/available', 'days/4/alreadyAssigned'],
                                            formatter: '.formatter.isDayEditableSimple'
                                        }"
                                        select=".onDaySelectedInTable"
                                        class="quotaDayCheckbox">
                                        <customData>
                                            <core:CustomData key="dayIndex" value="4" />
                                        </customData>
                                    </CheckBox>
                                </VBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

                <!-- Terms Checkboxes (obligatorios) -->
                <VBox class="quotaTermsContainer sapUiMediumMarginTop">
                    <HBox alignItems="Center" class="quotaTermsRow">
                        <CheckBox
                            id="termsCheckbox"
                            selected="{/termsAccepted}"
                            class="quotaTermsCheckbox" />
                        <Text text="Acepto las " class="quotaTermsText" />
                        <Link
                            text="condiciones y lineamientos"
                            press=".onOpenTermsAndConditions"
                            class="quotaTermsLink" />
                        <Text text=" del servicio" class="quotaTermsText" />
                    </HBox>
                    <HBox alignItems="Center" class="quotaTermsRow">
                        <CheckBox
                            id="privacyCheckbox"
                            selected="{/privacyAccepted}"
                            class="quotaTermsCheckbox" />
                        <Text text="Acepto la " class="quotaTermsText" />
                        <Link
                            text="política de tratamiento de datos personales"
                            press=".onOpenPrivacyPolicy"
                            class="quotaTermsLink" />
                    </HBox>
                </VBox>

                <!-- Action Buttons -->
                <HBox
                    justifyContent="End"
                    class="quotaActionButtons sapUiMediumMarginTop">
                    <Button
                        id="cancelButton"
                        text="Cancelar"
                        press=".onNavBack"
                        type="Default"
                        class="sapUiSmallMarginEnd" />
                    <Button
                        id="saveButton"
                        text="Aceptar"
                        press=".onSaveChanges"
                        type="Emphasized"
                        enabled="{= ${/termsAccepted} &amp;&amp; ${/privacyAccepted}}" />
                </HBox>

            </VBox>
        </content>

    </Page>
</mvc:View>
