{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/user-api/(.*)$",
      "target": "/user-api/$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/http/(.*)$",
      "target": "/http/$1",
      "destination": "dest_int_s",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/doc-condiciones$",
      "target": "/http",
      "destination": "DOC_CONDICIONES",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/doc-politicas$",
      "target": "/http",
      "destination": "DOC_POLITICAS",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
