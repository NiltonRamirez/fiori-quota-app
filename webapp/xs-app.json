{
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/destinations/dest_int_s/(.*)$",
      "target": "$1",
      "destination": "dest_int_s",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "localDir": ".",
      "authenticationType": "none",
      "csrfProtection": false
    }
  ]
}
