{
  "_version": "1.58.0",
  "sap.app": {
    "id": "com.ccb.quota",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "quotaService": {
        "uri": "/destinations/dest_int_s/http",
        "type": "JSON"
      }
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "fiori.quota.app"
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "rootView": {
      "viewName": "com.ccb.quota.view.App",
      "type": "XML",
      "async": true,
      "id": "appView"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.ccb.quota.i18n.i18n"
        }
      },
      "": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "com.ccb.quota.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteQuotaAssignment",
          "pattern": "",
          "target": ["TargetQuotaAssignment"]
        },
        {
          "name": "RouteMyAssignments",
          "pattern": "myAssignments",
          "target": ["TargetMyAssignments"]
        }
      ],
      "targets": {
        "TargetQuotaAssignment": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "QuotaAssignment",
          "viewName": "QuotaAssignment"
        },
        "TargetMyAssignments": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "MyAssignments",
          "viewName": "MyAssignments"
        }
      }
    }
  }
}
